# ---- Required to run the agent ----
# Get a free key at https://console.groq.com  (no credit card)
GROQ_API_KEY=

# ---- Optional overrides ----
GROQ_MODEL=llama-3.3-70b-versatile
CHROMA_PATH=storage/experiment_chroma
COLLECTION_NAME=banking_exp_full_e5_small_v2_1500_255
EMBEDDING_MODEL=intfloat/e5-small-v2
EMBEDDING_QUERY_PREFIX=query: 
EMBEDDING_PASSAGE_PREFIX=passage: 

# Comma-separated allowed origins for the frontend. Use * for local dev.
CORS_ORIGINS=*

# Web search tool (DuckDuckGo, no key needed). Set to false to disable.
ENABLE_WEB_SEARCH=true

# ---- Optional: OpenAI key (only for the embedding benchmark sweep) ----
# Needed solely to include text-embedding-3-small/-large in scripts/experiment.py.
OPENAI_API_KEY=

# ---- Optional: Langfuse observability (free cloud tier) ----
# Sign up at https://cloud.langfuse.com and paste the project keys here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
